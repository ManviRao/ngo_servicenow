        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	//  if (current.u_status != 'Approved') {
    //     return;
    // }

    var item = current.u_item_type ;    // donation item
    var qty = parseInt(current.u_quantity, 10); // donation quantity

    if (!item || qty <= 0) {
        return;
    }

    // Look for existing inventory
    var inv = new GlideRecord('x_1871156_ngo_do_0_inventory');
    inv.addQuery('item_name', item);
    inv.query();

    if (inv.next()) {

        // Update inventory quantity
		gs.info('Inventory exists. Updating quantity.');
        inv.available_quantiy = inv.available_quantiy + qty;
        inv.update();
    } else {
        // Create new inventory record
		gs.info('Inventory not found. Creating new record.');
        inv.initialize();
        inv.item_name = item;
        inv.available_quantiy = qty;
        inv.status = 'Available';
        inv.insert();
    }

})(current, previous);]]></script>
