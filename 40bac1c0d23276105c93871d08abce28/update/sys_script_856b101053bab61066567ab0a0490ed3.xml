        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	// // Safety check
    // if (current.state != 'Closed Complete') {
    //     return;
    // }

    // Get related donation
    var donation = current.related_donation.toString();
	
	gs.info('hi'+donation);
	
	
    if (!donation) {
        return;
    }

    var donationGR = new GlideRecord('x_1871156_ngo_do_0_u_partner_ngo_donations');
    if (!donationGR.get(donation)) {
        return;
    }
	

    var item = donationGR.u_item_type;
    var qty = parseInt(donationGR.u_quantity, 10);
	gs.info('hii'+item);
	gs.info('hii'+qty);


    // Reduce inventory
    var inv = new GlideRecord('x_1871156_ngo_do_0_inventory');
    inv.addQuery('item_name', item);
    inv.query();

    if (inv.next()) {
		gs.info("hii inside qunty");

        inv.available_quantiy -= qty;
		gs.info('hii before available qnty'+inv.available_quantiy);

        if (inv.available_quanty <= 0) {
            inv.available_quanty = 0;
            inv.status = 'Out of Stock';
        }
		gs.info('hii available quantity'+inv.available_quantiy);

        inv.update();
		gs.info('hi available quantity after update'+inv.available_quanty)
    }

})(current, previous);]]></script>
